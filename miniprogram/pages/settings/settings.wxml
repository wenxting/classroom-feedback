<view class="card">
  <view class="card-title">默认设置</view>
  <view class="form-group"><label>默认科目</label><input style="height: 66rpx; display: block; box-sizing: border-box" value="{{defaultSubject}}" bindinput="onInput" data-field="defaultSubject" placeholder="如：数学" /></view>
  <view class="form-group"><label>默认督学师</label><input style="height: 66rpx; display: block; box-sizing: border-box" value="{{defaultTeacher}}" bindinput="onInput" data-field="defaultTeacher" placeholder="如：文老师" /></view>
  <view class="form-group"><label>默认时间段</label><input style="height: 66rpx; display: block; box-sizing: border-box" value="{{defaultTime}}" bindinput="onInput" data-field="defaultTime" placeholder="如：15:00-17:00" /></view>
  <view class="form-group"><label>默认作业评语</label><input style="height: 66rpx; display: block; box-sizing: border-box" value="{{defaultHomework}}" bindinput="onInput" data-field="defaultHomework" placeholder="如：作业已完成" /></view>
  <view class="form-group"><label>DeepSeek API Key</label><input style="height: 66rpx; display: block; box-sizing: border-box" value="{{apiKey}}" bindinput="onInput" data-field="apiKey" placeholder="sk-xxxxxxxx" password /></view>
  <button class="btn btn-primary btn-full" bindtap="onSave">保存设置</button>
</view>

<view class="card">
  <view class="card-title">历史记录保留</view>
  <radio-group bindchange="onRetentionChange">
    <label style="display:flex;align-items:center;padding:8px 0"><radio value="never" checked="{{retention==='never'}}" /> 不自动清理</label>
    <label style="display:flex;align-items:center;padding:8px 0"><radio value="1month" checked="{{retention==='1month'}}" /> 保留1个月</label>
    <label style="display:flex;align-items:center;padding:8px 0"><radio value="3months" checked="{{retention==='3months'}}" /> 保留3个月</label>
  </radio-group>
</view>

<view class="card">
  <view class="card-title">使用统计</view>
  <text>已生成反馈：{{feedbackCount}} 条</text>
</view>

<view class="card" style="text-align:center">
  <text style="font-size:12px;color:#999">课堂反馈 v1.0.0</text>
</view>
